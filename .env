APP_NAME="ANICOM Store"
APP_ENV=local
APP_URL=http://localhost/anicom
APP_THEME=default
APP_LANG=en
APP_CURRENCY=USD
APP_DEBUG=false

# API — set a strong random string to protect the REST API
API_KEY=

DB_DRIVER=file
DB_HOST=127.0.0.1
DB_DATABASE=anicom_dev
DB_USERNAME=root
DB_PASSWORD=

MAIL_DRIVER=mail
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
